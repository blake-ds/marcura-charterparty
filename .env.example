# =====================================================================
# Charter Party Parser — environment template
# Copy to .env and fill in. Never commit .env (gitignored + gitleaks).
# =====================================================================

# ---------------------------------------------------------------------
# Azure LLM stack
# ---------------------------------------------------------------------
# Two endpoints in the Azure ecosystem:
#   - Azure OpenAI    →  gpt-5.4-nano, gpt-5.4-mini (reasoning + non-reasoning)
#   - Azure Foundry   →  Grok 4.1 Fast (reasoning + non-reasoning), DeepSeek-V4-Flash
#
# The verifier picks one deployment via MARCURA_VERIFIER_MODEL below.

MARCURA_AZURE_OPENAI_ENDPOINT=
MARCURA_AZURE_OPENAI_API_KEY=
MARCURA_AZURE_OPENAI_API_VERSION=2025-04-01-preview

MARCURA_AZURE_FOUNDRY_ENDPOINT=
MARCURA_AZURE_FOUNDRY_API_KEY=

# ---------------------------------------------------------------------
# Verifier deployment (must match an Azure deployment on the keys above)
# ---------------------------------------------------------------------
# DeepSeek-V4-Flash       — cheap, 1M context, strong instruction following
# gpt-5.4-nano            — Azure OpenAI reasoning, fast & cheap
# grok-4-1-fast-reasoning — Azure Foundry reasoning, fast
MARCURA_VERIFIER_MODEL=DeepSeek-V4-Flash

# ---------------------------------------------------------------------
# Reasoning-effort envelope per provider
# ---------------------------------------------------------------------
# GPT-5.4   accepts: minimal | low | medium | high | xhigh
# Grok 4.1  accepts: low | medium | high   (xhigh → decode_error)
# DeepSeek  accepts: low | medium | high   (medium is the documented sweet spot)

MARCURA_AZURE_OPENAI_REASONING_EFFORT=high
MARCURA_AZURE_FOUNDRY_REASONING_EFFORT=medium
